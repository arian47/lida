# ============================================================
# LIDA LLM Provider Configuration
# ============================================================
# Copy this file as .env and fill in your API keys.
# All values are loaded automatically by lida.llm at startup.
# ============================================================

# --- OpenAI / Azure OpenAI ---
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_API_TYPE=
OPENAI_API_VERSION=
OPENAI_ORGANIZATION=

# --- Google Gemini ---
GOOGLE_API_KEY=

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=

# --- MiniMax ---
MINIMAX_API_KEY=
MINIMAX_API_MODE=anthropic
# Base URLs (defaults are used if left blank):
#   Anthropic mode: https://api.minimax.io/anthropic
#   OpenAI mode:    https://api.minimax.io/v1
MINIMAX_ANTHROPIC_BASE_URL=
MINIMAX_OPENAI_BASE_URL=
